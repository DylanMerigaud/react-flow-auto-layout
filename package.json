{
  "name": "react-flow-auto-layout",
  "version": "0.1.1",
  "description": "Auto layout for React Flow, built on dagre: variable-size nodes, true bounding-box centering, and straightened linear segments (no kinked connectors).",
  "keywords": [
    "react-flow",
    "xyflow",
    "dagre",
    "layout",
    "auto-layout",
    "dag",
    "graph",
    "flowchart"
  ],
  "license": "MIT",
  "author": "Dylan Merigaud",
  "homepage": "https://github.com/DylanMerigaud/react-flow-auto-layout#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DylanMerigaud/react-flow-auto-layout.git"
  },
  "bugs": {
    "url": "https://github.com/DylanMerigaud/react-flow-auto-layout/issues"
  },
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "react": [
        "./dist/react/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "require": {
        "types": "./dist/react/index.d.cts",
        "default": "./dist/react/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "knip": "knip",
    "test": "tsx --test \"test/**/*.test.ts\"",
    "format": "prettier --write \"{src,test,eslint-rules}/**/*.ts\" \"*.{ts,mts,json}\"",
    "format:check": "prettier --check \"{src,test,eslint-rules}/**/*.ts\" \"*.{ts,mts,json}\"",
    "attw": "attw --pack .",
    "publint": "publint",
    "verify": "pnpm format:check && pnpm typecheck && pnpm lint && pnpm knip && pnpm test && pnpm build && pnpm publint && pnpm attw --pack .",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@xyflow/react": ">=12.0.0",
    "dagre": ">=0.8.5",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@eslint/js": "^9.39.4",
    "@types/dagre": "^0.7.54",
    "@types/node": "22.19.21",
    "@types/react": "19.2.17",
    "@typescript-eslint/utils": "^8.46.1",
    "@xyflow/react": "^12.11.1",
    "dagre": "^0.8.5",
    "eslint": "9",
    "eslint-config-prettier": "^10.1.8",
    "jiti": "^2.7.0",
    "knip": "6.16.1",
    "prettier": "3.8.4",
    "publint": "^0.3.0",
    "react": "19.2.7",
    "tsup": "^8.5.0",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8"
  }
}
